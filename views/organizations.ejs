<%- include("partials/header", { title: title }) %>

    <main class="container">
        <h1>Organizations</h1>
        <ul>
            <% organizations.forEach(organization=> { %>
                <li>
                    <strong>
                        <%= organization.organization_name %>
                    </strong>
                    - <%= organization.phone %>
                        - <%= organization.email %>
                </li>
                <% }) %>
        </ul>
    </main>

    <%- include("partials/footer") %>